# ── Backend Calls ────────────────────────────────────────────────────────

def run_script(*args):
    try:
        r = subprocess.run(
            ["sudo", SCRIPT] + list(args),
            capture_output=True, text=True, timeout=30
        )
        return r.returncode, r.stdout, r.stderr
    except Exception as e:
        return -1, "", str(e)


def get_tor_status():
    tor = False
    proxy = False
    try:
        r = subprocess.run(["systemctl", "is-active", "tor"],
                           capture_output=True, text=True, timeout=5)
        tor = r.stdout.strip() == "active"
    except: pass

    try:
        r = subprocess.run(["sudo", "iptables", "-t", "nat", "-L", "OUTPUT", "-n"],
                           capture_output=True, text=True, timeout=5)
        proxy = "REDIRECT" in r.stdout
    except: pass

    return tor, proxy


def get_public_ips():
    """Returns (direct_ip, tor_exit_ip, is_tor, tor_country) — PARALLEL"""
    result = {"direct": "?", "tor": "?", "is_tor": False, "country": "?"}
    results = {}

    def _fetch_direct():
        try:
            r = subprocess.run(
                ["curl", "-4", "--connect-timeout", "3", "-s", "https://ifconfig.me"],
                capture_output=True, text=True, timeout=6
            )
            if r.stdout.strip():
                results["direct"] = r.stdout.strip()
        except: pass

    def _fetch_tor():
        try:
            r = subprocess.run(
                ["curl", "-4", "--connect-timeout", "3", "-s",
                 "--socks5-hostname", "127.0.0.1:9050",
                 "https://ipinfo.io/json"],
                capture_output=True, text=True, timeout=8
            )
            if r.stdout.strip():
                data = json.loads(r.stdout)
                results["tor"] = data.get("ip", "?")
                results["country"] = data.get("country", "?")
                results["is_tor"] = True
        except: pass

    t1 = threading.Thread(target=_fetch_direct, daemon=True)
    t2 = threading.Thread(target=_fetch_tor, daemon=True)
    t1.start()
    t2.start()
    t1.join(timeout=7)
    t2.join(timeout=9)

    if "direct" in results:
        result["direct"] = results["direct"]
    if "tor" in results:
        result["tor"] = results["tor"]
        result["country"] = results["country"]
        result["is_tor"] = True

    return result


def new_tor_circuit():
    """Send NEWNYM signal to Tor control port."""
    try:
        with open(TOR_COOKIE, "rb") as f:
            cookie = f.read()
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(10)
        s.connect(("127.0.0.1", TOR_CONTROL_PORT))

        hex_cookie = cookie.hex()
        s.sendall(f"AUTHENTICATE {hex_cookie}\r\n".encode())
        resp = s.recv(1024)
        if "250" not in resp.decode(errors="ignore"):
            s.close()
            return False, "Auth failed"

        s.sendall(b"SIGNAL NEWNYM\r\n")
        resp = s.recv(1024)
        s.close()

        if "250" in resp.decode(errors="ignore"):
            return True, "New circuit requested"
        return False, f"Signal failed: {resp.decode(errors='ignore')}"
    except Exception as e:
        return False, str(e)


def set_exit_country(country_code):
    """Set ExitNodes in torrc and reload Tor."""
    try:
        with open(TORRC, "r") as f:
            lines = f.readlines()
    except: lines = []

    new_lines = []
    for line in lines:
        if line.strip().startswith("ExitNodes") or line.strip().startswith("StrictExitNodes"):
            continue
        new_lines.append(line)

    while new_lines and new_lines[-1].strip() == "":
        new_lines = new_lines[:-1]

    if country_code:
        new_lines.append(f"\n# Set by Tor App Manager\n")
        new_lines.append(f"ExitNodes {{{country_code}}}\n")
        new_lines.append("StrictExitNodes 1\n")
    else:
        new_lines.append(f"\n# ExitNodes cleared by Tor App Manager\n")

    with open(TORRC, "w") as f:
        f.writelines(new_lines)

    r = subprocess.run(["sudo", "systemctl", "reload", "tor"],
                       capture_output=True, text=True, timeout=10)
    return r.returncode == 0, r.stdout + r.stderr


def get_current_exit_country():
    """Read current ExitNodes from torrc."""
    try:
        with open(TORRC, "r") as f:
            for line in f:
                m = re.search(r"ExitNodes\s*\{(\w+)\}", line)
                if m:
                    return m.group(1).lower()
    except: pass
    return ""


def measure_tor_latency():
    """Measure latency through Tor — PARALLEL, fast timeout."""
    import time
    times = [None, None, None]

    def _ping(idx):
        try:
            r = subprocess.run(
                ["curl", "-4", "--connect-timeout", "5", "--max-time", "8", "-s", "-o", "/dev/null",
                 "-w", "%{time_total}", "--socks5-hostname", "127.0.0.1:9050",
                 "https://check.torproject.org/"],
                capture_output=True, text=True, timeout=10
            )
            if r.stdout.strip():
                times[idx] = float(r.stdout.strip())
        except: pass

    threads = [threading.Thread(target=_ping, args=(i,), daemon=True) for i in range(3)]
    for t in threads:
        t.start()
    for t in threads:
        t.join(timeout=12)

    valid = [t for t in times if t is not None]
    if valid:
        avg = sum(valid) / len(valid)
        return avg * 1000, f"{avg*1000:.0f} ms ({len(valid)}/3)"
    return 0, "timeout"


