        self.rotate_btn.setText("🌀 Rotating...")
        self.tool_output.setText("Requesting new circuit...")

        def _do():
            ok, msg = new_tor_circuit()
            QTimer.singleShot(0, lambda: self._rotate_result(ok, msg))

        threading.Thread(target=_do, daemon=True).start()

    def _rotate_result(self, ok, msg):
        self.rotate_btn.setEnabled(True)
        self.rotate_btn.setText("🔄 New IP")
        if ok:
            self.tool_output.setText("✔ New circuit established. Waiting for new IP...")
            QTimer.singleShot(3000, self._refresh_ips)
        else:
            self.tool_output.setText(f"✖ {msg}")

    def _test_latency(self):
        self.ping_btn.setEnabled(False)
        self.ping_btn.setText("⏳ Testing...")
        self.tool_output.setText("Measuring Tor latency (parallel)...")

        def _do():
            ms, text = measure_tor_latency()
            QTimer.singleShot(0, lambda: self._latency_result(ms, text))

        threading.Thread(target=_do, daemon=True).start()

    def _latency_result(self, ms, text):
        self.ping_btn.setEnabled(True)
        self.ping_btn.setText("📡 Test Latency")
        if ms:
            color = "green" if ms < 2000 else ("orange" if ms < 5000 else "red")
            self.tool_output.setText(
                f"Tor latency: <span style='color:{color}; font-weight:bold;'>{text}</span>"
            )
        else:
            self.tool_output.setText("✖ Latency test failed (Tor not running?)")

