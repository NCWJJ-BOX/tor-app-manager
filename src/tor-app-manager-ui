class StatusDot(QWidget):
    """Animated status indicator — drawn with QPainter, no emoji."""
    def __init__(self, parent=None):
        super().__init__(parent)
        self._color = QColor(CLR["disabled"])
        self._pulse = 1.0
        self._dir = -1
        self._animating = False
        self._timer = QTimer(self)
        self._timer.timeout.connect(self._tick)
        self.setFixedSize(28, 28)

    def set_color(self, color_hex, animate=False):
        self._color = QColor(color_hex)
        if animate and not self._animating:
            self._animating = True
            self._timer.start(40)
        elif not animate:
            self._animating = False
            self._timer.stop()
            self._pulse = 1.0
        self.update()

    def _tick(self):
        self._pulse += 0.04 * self._dir
        if self._pulse <= 0.6:
            self._dir = 1
        elif self._pulse >= 1.0:
            self._dir = -1
        self.update()

    def paintEvent(self, event):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        rect = self.rect().adjusted(3, 3, -3, -3)
        r = rect.width() // 2
        center = rect.center()

        # glow ring
        glow_r = r * (1.5 + (1.0 - self._pulse) * 0.7) if self._animating else r * 1.3
        grad = QRadialGradient(center, glow_r)
        c = QColor(self._color)
        c.setAlpha(int(50 * self._pulse))
        grad.setColorAt(0, c)
        grad.setColorAt(0.4, c)
        grad.setColorAt(1, QColor(0, 0, 0, 0))
        p.setBrush(QBrush(grad))
        p.setPen(Qt.NoPen)
        p.drawEllipse(center, glow_r, glow_r)

        # core dot
        p.setBrush(self._color)
        p.setPen(QPen(self._color.lighter(140), 1))
        p.drawEllipse(center, r * self._pulse, r * self._pulse)

        # inner highlight
        if self._animating:
            hl = QColor(255, 255, 255, int(40 + (1.0 - self._pulse) * 40))
            p.setBrush(hl)
            p.setPen(Qt.NoPen)
            p.drawEllipse(center, r * 0.35, r * 0.35)


