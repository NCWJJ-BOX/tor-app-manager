    def _make_icon(self, color_hex):
        size = 64
        pixmap = QPixmap(size, size)
        pixmap.fill(Qt.transparent)
        painter = QPainter(pixmap)
        painter.setRenderHint(QPainter.Antialiasing)
        painter.setBrush(QColor(color_hex))
        painter.setPen(Qt.NoPen)
        painter.drawEllipse(4, 4, size - 8, size - 8)
        painter.setPen(QColor("white"))
        font = QFont("sans-serif", 28, QFont.Bold)
        painter.setFont(font)
        painter.drawText(pixmap.rect(), Qt.AlignCenter, "T")
        painter.end()
        return QIcon(pixmap)

    def _tray_click(self, reason):
        if reason == QSystemTrayIcon.DoubleClick:
            self.show_normal()

    def show_normal(self):
        self.show()
        self.raise_()
        self.activateWindow()
        self._refresh_all()

    def closeEvent(self, event):
        event.ignore()
        self.hide()
        self.tray_icon.showMessage(
            "Tor App Manager",
            "Minimized to tray. Double-click to reopen.",
            QSystemTrayIcon.Information, 2000
        )

    def _toggle_proxy(self):
        if not self.tor_active:
            self.tool_output.setText("Tor is not running. Start Tor first.")
            return

        turning_on = not self.proxy_active
        self.toggle_btn.setEnabled(False)
        self.toggle_btn.setText("STOPPING..." if turning_on else "STARTING...")
        self.tool_output.setText("Working...")

        def _do():
            action = "start" if turning_on else "stop"
            rc, out, err = run_script(action)
            QTimer.singleShot(0, self._refresh_all)

        threading.Thread(target=_do, daemon=True).start()

    def _apply_country(self):
        code = self.country_combo.currentData()
        self.apply_country_btn.setEnabled(False)
        self.country_status.setText("Applying...")

        def _do():
            ok, msg = set_exit_country(code)
            QTimer.singleShot(0, lambda: self._country_result(ok, msg))

        threading.Thread(target=_do, daemon=True).start()

    def _country_result(self, ok, msg):
        self.apply_country_btn.setEnabled(True)
        if ok:
            code = self.country_combo.currentData()
            name = COUNTRIES.get(code, "Random")
            self.country_status.setText(f"✔ ExitNodes set to {name}")
            QTimer.singleShot(2000, self._refresh_ips)
        else:
            self.country_status.setText(f"✖ Failed: {msg[:50]}")

    def _on_country_change(self):
        code = self.country_combo.currentData()
        self._apply_country()

