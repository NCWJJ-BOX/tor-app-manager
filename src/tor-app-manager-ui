    def _make_icon(self, color_hex):
        size = 64
        pixmap = QPixmap(size, size)
        pixmap.fill(Qt.transparent)
        painter = QPainter(pixmap)
        painter.setRenderHint(QPainter.Antialiasing)

        # Shield shape
        c = QColor(color_hex)
        path = QPainterPath()
        m = 6  # margin
        w = size - 2 * m
        h = size - 2 * m
        path.moveTo(m + w / 2, m)                    # top center
        path.lineTo(m + w, m + h * 0.25)              # top right
        path.lineTo(m + w, m + h * 0.55)              # mid right
        path.cubicTo(m + w, m + h * 0.75, m + w * 0.75, m + h, m + w / 2, m + h)  # bottom curve
        path.cubicTo(m + w * 0.25, m + h, m, m + h * 0.75, m, m + h * 0.55)        # bottom left curve
        path.lineTo(m, m + h * 0.25)                  # top left
        path.closeSubpath()

        # Outer glow
        glow = QColor(color_hex)
        glow.setAlpha(40)
        glow_path = QPainterPath()
        glow_path.addEllipse(m - 2, m - 2, w + 4, h + 4)
        painter.setBrush(glow)
        painter.setPen(Qt.NoPen)
        painter.drawPath(glow_path)

        # Shield fill
        fill = QColor(color_hex)
        fill.setAlpha(60)
        painter.setBrush(fill)
        painter.setPen(QPen(c, 2))
        painter.drawPath(path)

        # "T" letter inside shield
        painter.setPen(c.lighter(150))
        font = QFont("sans-serif", 22, QFont.Bold)
        painter.setFont(font)
        painter.drawText(pixmap.rect(), Qt.AlignCenter, "T")

        painter.end()
        return QIcon(pixmap)

    def _tray_click(self, reason):
        if reason == QSystemTrayIcon.DoubleClick:
            self.show_normal()

    def show_normal(self):
        self.show()
        self.raise_()
        self.activateWindow()
        self._refresh_all()

    def closeEvent(self, event):
        event.ignore()
        self.hide()
        self.tray_icon.showMessage(
            "Tor App Manager",
            "Minimized to tray. Double-click to reopen.",
            QSystemTrayIcon.Information, 2000
        )

    def _toggle_proxy(self):
        if not self.tor_active:
            self.tool_output.setText("Tor is not running. Start Tor first.")
            return

        turning_on = not self.proxy_active
        self.toggle_btn.setEnabled(False)
        self.toggle_btn.setText("STOPPING..." if turning_on else "STARTING...")
        self.tool_output.setText("Working...")

        def _do():
            action = "start" if turning_on else "stop"
            rc, out, err = run_script(action)
            QTimer.singleShot(0, self._refresh_all)

        threading.Thread(target=_do, daemon=True).start()

    def _apply_country(self):
        code = self.country_combo.currentData()
        self.apply_country_btn.setEnabled(False)
        self.country_status.setText("Applying...")

        def _do():
            ok, msg = set_exit_country(code)
            QTimer.singleShot(0, lambda: self._country_result(ok, msg))

        threading.Thread(target=_do, daemon=True).start()

    def _country_result(self, ok, msg):
        self.apply_country_btn.setEnabled(True)
        if ok:
            code = self.country_combo.currentData()
            name = COUNTRIES.get(code, "Random")
            self.country_status.setText(f"ExitNodes set to {name}")
            QTimer.singleShot(2000, self._refresh_ips)
        else:
            self.country_status.setText(f"Failed: {msg[:50]}")

    def _on_country_change(self):
        code = self.country_combo.currentData()
        self._apply_country()

    def _rotate_ip(self):
        self.rotate_btn.setEnabled(False)
        self.rotate_btn.setText("Rotating...")
        self.tool_output.setText("Requesting new circuit...")

        def _do():
            ok, msg = new_tor_circuit()
            QTimer.singleShot(0, lambda: self._rotate_result(ok, msg))

        threading.Thread(target=_do, daemon=True).start()

    def _rotate_result(self, ok, msg):
        self.rotate_btn.setEnabled(True)
        self.rotate_btn.setText("New IP")
        if ok:
            self.tool_output.setText("New circuit established. Waiting for new IP...")
            QTimer.singleShot(3000, self._refresh_ips)
        else:
            self.tool_output.setText(f"{msg}")

    def _test_latency(self):
        self.ping_btn.setEnabled(False)
        self.ping_btn.setText("Testing...")
        self.tool_output.setText("Measuring Tor latency (parallel)...")

        def _do():
            ms, text = measure_tor_latency()
            QTimer.singleShot(0, lambda: self._latency_result(ms, text))

        threading.Thread(target=_do, daemon=True).start()

    def _latency_result(self, ms, text):
        self.ping_btn.setEnabled(True)
        self.ping_btn.setText("Test Latency")
        if ms:
            color = "green" if ms < 2000 else ("orange" if ms < 5000 else "red")
            self.tool_output.setText(
                f"Tor latency: <span style='color:{color}; font-weight:bold;'>{text}</span>"
            )
        else:
            self.tool_output.setText("Latency test failed (Tor not running?)")

    def _copy_tor_ip(self):
        ip = self.ips["tor"]
        if ip and ip != "?":
            cb = QApplication.clipboard()
            cb.setText(ip)
            self.tool_output.setText(f"Copied: {ip}")
        else:
            self.tool_output.setText("No Tor IP available")

    def _refresh_status(self):
        def _do():
            tor, proxy = get_tor_status()
            self.tor_active = tor
            self.proxy_active = proxy
            QTimer.singleShot(0, self._update_ui)
        threading.Thread(target=_do, daemon=True).start()

    def _refresh_ips(self):
        def _do():
            ips = get_public_ips()
            self.ips = ips
            QTimer.singleShot(0, self._update_ip_ui)
        threading.Thread(target=_do, daemon=True).start()

    def _refresh_all(self):
        self._refresh_status()
        QTimer.singleShot(100, self._refresh_ips)

    def _update_ui(self):
        if self.proxy_active:
            self.status_dot.set_color(CLR['success'], animate=True)
            self.status_text.setText("ACTIVE — All traffic through Tor")
            self.status_detail.setText("Transparent proxy engaged")
            self.toggle_btn.setText("Stop Proxy")
            self.toggle_btn.setStyleSheet(f"""
                QPushButton {{
                    font-size: 13px; font-weight: bold; padding: 10px 20px;
                    border-radius: 6px; background: {CLR['danger']}; color: white;
                }}
                QPushButton:hover {{ background: #c0392b; }}
                QPushButton:disabled {{ background: {CLR['disabled']}; color: #777; }}
                QPushButton:focus {{ outline: 2px solid {CLR['primary']}; outline-offset: 2px; }}
            """)
            icon_color = CLR['success']
        elif self.tor_active:
            self.status_dot.set_color(CLR['warning'], animate=True)
            self.status_text.setText("Tor running — Proxy OFF")
            self.status_detail.setText("Click START to enable transparent proxy")
            self.toggle_btn.setText("Start Proxy")
            self.toggle_btn.setStyleSheet(f"""
                QPushButton {{
                    font-size: 13px; font-weight: bold; padding: 10px 20px;
                    border-radius: 6px; background: {CLR['success']}; color: white;
                }}
                QPushButton:hover {{ background: #10b981; }}
                QPushButton:disabled {{ background: {CLR['disabled']}; color: #777; }}
                QPushButton:focus {{ outline: 2px solid {CLR['primary']}; outline-offset: 2px; }}
            """)
            icon_color = CLR['warning']
        else:
            self.status_dot.set_color(CLR['danger'], animate=True)
            self.status_text.setText("Tor NOT running")
            self.status_detail.setText("Run 'sudo systemctl start tor' first")
            self.toggle_btn.setText("Start Proxy")
            self.toggle_btn.setStyleSheet(f"""
                QPushButton {{
                    font-size: 13px; font-weight: bold; padding: 10px 20px;
                    border-radius: 6px; background: {CLR['disabled']}; color: #777;
                }}
                QPushButton:focus {{ outline: 2px solid {CLR['primary']}; outline-offset: 2px; }}
            """)
            icon_color = CLR['danger']

        self.toggle_btn.setEnabled(self.tor_active)
        self.tray_icon.setIcon(self._make_icon(icon_color))
        self.tray_toggle.setText("Stop Proxy" if self.proxy_active else "Start Proxy")

    def _update_ip_ui(self):
        ips = self.ips
        self.direct_ip_label.setText(ips["direct"] or "blocked")
        self.tor_ip_label.setText(ips["tor"] or "N/A")

        country = ips.get("country", "?")
        for code, name in COUNTRIES.items():
            if code and code.upper() == country:
                self.exit_country_label.setText(name)
                break
        else:
            self.exit_country_label.setText(country)

        if ips["is_tor"]:
            self.tor_check_label.setText("YES (traffic via Tor)")
            self.tor_check_label.setStyleSheet(f"font-size: 11px; color: {CLR['success']}; font-weight: bold;")
        else:
            self.tor_check_label.setText("NO")
            self.tor_check_label.setStyleSheet(f"font-size: 11px; color: {CLR['danger']}; font-weight: bold;")

        if ips["tor"] and ips["tor"] != "?":
            self.tray_ip.setText(f"Tor IP: {ips['tor']}")

    def _quit(self):
        # Stop transparent proxy on exit
        try:
            subprocess.run(["sudo", SCRIPT, "stop"], capture_output=True, timeout=15)
        except: pass
        self.tray_icon.hide()
        self.close()
        QApplication.quit()


